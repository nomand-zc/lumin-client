{
    "model": "claude-sonnet-4.5",
    "stream": true,
    "tools": [
        {
            "name": "get_weather",
            "description": "查询指定城市的天气情况，包括温度、湿度、天气状况等信息",
            "parameters": {
                "type": "object",
                "properties": {
                    "city": {
                        "type": "string",
                        "description": "要查询天气的城市名称，例如：北京、上海、广州"
                    },
                    "date": {
                        "type": "string",
                        "description": "要查询的日期，格式为 YYYY-MM-DD，默认为今天"
                    }
                },
                "required": [
                    "city"
                ]
            }
        },
        {
            "name": "web_search",
            "description": "Search the web for real-time information, news, and current events",
            "parameters": {
                "type": "object",
                "properties": {
                    "query": {
                        "type": "string",
                        "description": "The search query to look up"
                    }
                },
                "required": [
                    "query"
                ]
            }
        }
    ],
    "messages": [
        {
            "role": "system",
            "content": "你是一个有用的AI助手，请用中文回答用户的问题。如果需要，请使用工具获取实时信息。回答完毕后请给出后续建议问题。"
        },
        {
            "role": "user",
            "content": "请帮我分析一下北京和上海明天的天气情况，并给出穿衣建议。如果可能的话，也搜索一下最近的天气预警信息。"
        }
    ],
    "generation_config": {
        "max_tokens": 4096,
        "temperature": 0.7,
        "top_p": 0.9,
        "stream": true,
        "thinking_enabled": true,
        "thinking_tokens": 16000,
        "reasoning_effort": "high"
    }
}